# ===== Документы =====
# Папка с исходниками (прайсы, презентации, записи обучения и т.д.)
DOCS_DIR=/opt/db

# ===== Модели =====
# Выбор модели генерации по памяти — см. docs/MODELS.md:
#   8–16 ГБ: qwen3:8b, gemma3:12b ; 24 ГБ: qwen2.5:32b, qwen3.6:35b-a3b ; 48–96 ГБ: qwen2.5:72b
LLM_MODEL=qwen2.5:32b-instruct-q4_K_M
OLLAMA_URL=http://localhost:11434
EMBED_MODEL=BAAI/bge-m3            # эмбеддер: BAAI/bge-m3 (1024d) — см. docs/MODELS.md
RERANK_MODEL=BAAI/bge-reranker-v2-m3
DEVICE=mps                       # mps (Apple), cuda или cpu

# ===== Qdrant =====
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=company_kb

# ===== Параметры RAG =====
CHUNK_SIZE=900                   # размер чанка в символах
CHUNK_OVERLAP=150
TOP_K_RETRIEVE=20                # сколько достаём из БД
TOP_K_RERANK=6                   # сколько оставляем после реранка
MIN_SCORE=0.30                   # порог релевантности (0..1) — ниже = "не знаю"

# ===== Транскрибация =====
WHISPER_MODEL=mlx-community/whisper-large-v3-turbo

# ===== Доступ =====
API_HOST=0.0.0.0
API_PORT=8000
# Пароль админ-панели. Пусто = без пароля (только для доверенной локальной сети!)
ADMIN_TOKEN=
