# ===== Документы =====
DOCS_DIR=/opt/db

# ===== Генерация: vLLM (OpenAI-совместимый сервер) =====
LLM_BACKEND=openai
LLM_BASE_URL=http://localhost:8001/v1
LLM_API_KEY=EMPTY
# Модель = тот же id, что отдаёт vLLM (см. VLLM_MODEL в docker-compose.gpu.yml)
# Выбор по VRAM (docs/MODELS.md): 24 ГБ → 14B-AWQ; 48 ГБ → 32B-AWQ; 80 ГБ → 72B-AWQ.
LLM_MODEL=Qwen/Qwen2.5-14B-Instruct-AWQ

# ===== Эмбеддинги / реранк на GPU =====
EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3
DEVICE=cuda

# ===== Qdrant =====
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=company_kb

# ===== Параметры RAG =====
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K_RETRIEVE=20
TOP_K_RERANK=6
MIN_SCORE=0.30

# ===== Транскрибация =====
WHISPER_BACKEND=faster
WHISPER_MODEL=large-v3

# ===== Доступ =====
API_HOST=0.0.0.0
API_PORT=8000
# Пароль админ-панели. Пусто = без пароля (только для доверенной локальной сети!)
ADMIN_TOKEN=
