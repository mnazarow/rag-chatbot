# Настройки приложения внутри контейнера (Docker-вариант с Redis).
# Скопируйте в .env.docker и при необходимости поправьте.
# Файл общий для Windows, Linux и macOS.

# ===== Документы (путь ВНУТРИ контейнера, не трогать) =====
DOCS_DIR=/data/docs

# ===== Вычисления =====
DEVICE=cpu                       # в контейнере — CPU (для GPU см. gpu_variant)

# ===== Модель генерации (Ollama на ХОСТЕ) =====
# На CPU выбирайте модель поменьше: 7B отвечает за секунды, 32B будет очень медленной.
LLM_MODEL=qwen3.6:35b-a3b-q4_K_M
OLLAMA_URL=http://host.docker.internal:11434

# ===== Эмбеддинги и реранк =====
EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ===== Qdrant (адрес контейнера в сети compose) =====
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=company_kb

# ===== Кэш Redis (ВКЛЮЧЁН и настроен; сервис redis в сети compose) =====
REDIS_ENABLED=1
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=                # заполните, если включили requirepass в redis.conf

# ===== База данных журнала/настроек =====
# По умолчанию SQLite (локальный файл). Можно переключить на внешний MySQL/PostgreSQL
# в админке (раздел «База данных и кэш») или здесь:
# DB_BACKEND=sqlite             # sqlite | mysql | postgresql

# ===== Параметры RAG =====
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K_RETRIEVE=20
TOP_K_RERANK=6
MIN_SCORE=0.30

# ===== Транскрибация аудио/видео (на CPU) =====
WHISPER_BACKEND=faster
WHISPER_MODEL=base

# ===== Тяжёлые экстракторы при индексации (на CPU медленно) =====
OCR_IMAGES=1
OCR_RAW=1
PARSE_CAD=1
TRANSCRIBE_AV=1
FILE_PARSE_TIMEOUT=0

# ===== Доступ =====
API_HOST=0.0.0.0
API_PORT=8000
# Пароль админ-панели. Пусто = без пароля (только для доверенной локальной сети!)
ADMIN_TOKEN=
