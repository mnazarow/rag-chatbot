# Настройки приложения внутри контейнера (Docker на Windows).
# Скопируйте в .env.docker и при необходимости поправьте.

# ===== Документы (путь ВНУТРИ контейнера, не трогать) =====
DOCS_DIR=/data/docs

# ===== Вычисления =====
DEVICE=cpu                       # в контейнере на Windows — только CPU

# ===== Модель генерации (Ollama на хосте Windows) =====
# На CPU выбирайте модель поменьше: 7B отвечает за секунды, 32B будет очень медленной.
LLM_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_URL=http://host.docker.internal:11434

# ===== Эмбеддинги и реранк =====
EMBED_MODEL=BAAI/bge-m3
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# ===== Qdrant (адрес контейнера в сети compose) =====
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=company_kb

# ===== Параметры RAG =====
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K_RETRIEVE=20
TOP_K_RERANK=6
MIN_SCORE=0.30

# ===== Транскрибация аудио/видео (на CPU) =====
WHISPER_BACKEND=faster           # faster-whisper (CPU/GPU), без Apple-mlx
WHISPER_MODEL=base               # на CPU быстрее; для качества — small/medium/large-v3

# ===== Доступ =====
API_HOST=0.0.0.0
API_PORT=8000
# Пароль админ-панели. Пусто = без пароля (только для доверенной локальной сети!)
ADMIN_TOKEN=
